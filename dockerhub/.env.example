# =============================================================================
# Tangerine Configuration — Copy this file to .env and customize
# =============================================================================
# REQUIRED: Change these before deploying to production!
# These settings take effect on first run. Changing them later can cause issues.

# ----- Domain & Protocol -----
# The domain name where Tangerine will be accessed (e.g., tangerine.example.com)
T_HOST_NAME=localhost
# Set to "https" if you have SSL configured behind a reverse proxy
T_PROTOCOL=http

# ----- Admin & Users -----
# Super admin user credentials (change these!)
T_USER1=user1
T_USER1_PASSWORD=password
# Upload token used by tablets to authenticate (Sync Protocol 1)
T_UPLOAD_TOKEN=password

# ----- CouchDB Database -----
# Admin credentials for CouchDB (change these!)
T_COUCHDB_USER_ADMIN_NAME=admin
T_COUCHDB_USER_ADMIN_PASS=password

# ----- Modules -----
# Available modules: csv, logstash, class, case, sync-protocol-2
# Example: T_MODULES="['csv','case']"
T_MODULES="['csv']"

# ----- Email -----
T_MAINTAINER_EMAIL=admin@example.com

# =============================================================================
# Optional Settings
# =============================================================================

# ----- Reporting -----
T_REPORTING_DELAY=300000
T_PAID_MODE=site
T_PAID_ALLOWANCE=unlimited
T_CSV_BATCH_SIZE=50
T_LIMIT_NUMBER_OF_CHANGES=200

# ----- Sync -----
T_LEGACY=false
T_CENTRALLY_MANAGED_USER_PROFILE=false
T_USER_SHORT_CODE_LENGTH=6
T_UPLOAD_WITHOUT_UPDATING_REV=true

# ----- Auto Commit -----
T_AUTO_COMMIT=true
T_AUTO_COMMIT_FREQUENCY=60000

# ----- Replication -----
T_REPLICATE=[]

# ----- JWT -----
T_JWT_ISSUER=Tangerine
T_JWT_EXPIRES_IN=1h
T_JWT_SIGNING_ALGORITHM=HS256
T_JWT_VERIFICATION_ALGORITHMS=['HS256', 'HS384', 'HS512']

# ----- Password Policy -----
T_PASSWORD_POLICY=^(?=.*[a-z])(?=.*[A-Z])(?=.*[0-9])(?=.*[~!@#$%^&*()\-_=+<>,.;:|[\]{}])(?=.{8,})

# ----- UI/UX -----
T_HIDE_PROFILE=false
T_HIDE_SKIP_IF=true
T_ORIENTATION=any
T_CUSTOM_LOGIN_MARKUP=

# ----- Archiving -----
T_ARCHIVE_APKS_TO_DISK=true
T_ARCHIVE_PWAS_TO_DISK=true

# ----- Port Mapping -----
# Set to "8080:80" to run on port 8080 instead of 80
T_PORT_MAPPING=80:80

# ----- Docker Image Tag -----
# Override the image tag (defaults to "latest")
T_TAG=

# ----- Docker Image Prefix -----
# Docker Hub username or org hosting the images (defaults to "tangerine")
# If you published under your own account, set this:
# IMAGE_PREFIX=yourdockerhubusername
IMAGE_PREFIX=
